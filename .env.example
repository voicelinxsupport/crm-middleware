# =============================================
# Bicom CRM Middleware - Konfigürasyon
# Bu dosyayı .env olarak kopyala ve doldur
# =============================================

# Sunucu portu (default: 3000)
PORT=3000

# JWT imzalama secretı — rastgele uzun bir string gir
# Örnek: openssl rand -hex 32
JWT_SECRET=buraya-cok-uzun-ve-rastgele-bir-secret-yaz

# JWT token süresi
JWT_EXPIRES_IN=24h

# =============================================
# Salesforce Connected App Bilgileri
# Salesforce Setup > App Manager > New Connected App
# =============================================
SALESFORCE_CLIENT_ID=3MVG9...buraya_consumer_key
SALESFORCE_CLIENT_SECRET=buraya_consumer_secret

# Salesforce instance domain'in (org URL'inden al)
# Örnek: mycompany.my.salesforce.com
SALESFORCE_DOMAIN=mycompany.my.salesforce.com

# OAuth callback URL — bu middleware'in public URL'i + /salesforce/user/callback/code
# Salesforce Connected App'e de bu URL'i eklemen gerekiyor
SALESFORCE_CALLBACK_URL=https://senin-middleware-url.com/salesforce/user/callback/code

# =============================================
# Veritabanı (SQLite — dosya adı)
# =============================================
DB_PATH=./middleware.db
